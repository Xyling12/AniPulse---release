<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AnimeLib" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#0F0F13</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Системный сплэш (Android 12+ нативно, ниже — через compat-библиотеку core-splashscreen):
         тёмный фон вместо белого по умолчанию, чтобы не было вспышки перед анимацией в Compose. -->
    <style name="Theme.AnimeLib.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0C0C12</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AnimeLib</item>
    </style>
</resources>
